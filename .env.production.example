# Production Environment Variable Template
# Copy this to .env.production and fill to run the local server securely

# (REQUIRED) HuggingFace API Token used for BGE Small embedding pipelines
HF_TOKEN=hf_your_hugging_face_token_here

# (REQUIRED) OpenAI API Key / Or secondary HuggingFace endpoint key for text Generation
OPENAI_API_KEY=your_openai_or_secondary_key_here

# (OPTIONAL) Application Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# (OPTIONAL) Runtime Port for API
PORT=8000
